  "keyFeatures": [
    "Intelligent PGCR crawler with adaptive scaling (Atlas)",
    "Bungie API reverse proxy with IPv6 load balancing (Zeus)",
    "Self-scaling queue worker manager (Hermes)",
    "Multi-database storage (PostgreSQL + ClickHouse)",
    "Comprehensive cheat detection system",
    "Event-driven message queue architecture",
    "Docker-based infrastructure orchestration",
    "Prometheus metrics and monitoring"
  ],
  "publicApiSurface": [
    "Atlas - PGCR Crawler Service (port 8080)",
    "Zeus - Bungie API Proxy (port 7777)",
    "Hermes - Queue Worker Manager (port 8081)",
    "RabbitMQ Message Queues (port 5672)",
    "PostgreSQL Database (port 5432)",
    "ClickHouse Analytics (port 9000/8123)",
    "Prometheus Metrics (port 9090)"
  ]
